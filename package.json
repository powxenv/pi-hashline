{
  "name": "pi-hashline",
  "version": "0.1.0",
  "description": "Pi extension for hashline-anchored reads, search, edits, file maps, file exploration, and shell compaction",
  "keywords": [
    "code-map",
    "hashline",
    "pi-extension",
    "pi-package"
  ],
  "license": "MIT",
  "files": [
    "index.ts",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "module": "index.ts",
  "exports": {
    ".": "./index.ts"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "test": "bun test",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:fix": "oxfmt --fix",
    "knip": "knip"
  },
  "dependencies": {
    "@ast-grep/lang-bash": "^0.0.8",
    "@ast-grep/lang-c": "^0.0.6",
    "@ast-grep/lang-cpp": "^0.0.6",
    "@ast-grep/lang-go": "^0.0.6",
    "@ast-grep/lang-java": "^0.0.7",
    "@ast-grep/lang-kotlin": "^0.0.7",
    "@ast-grep/lang-python": "^0.0.6",
    "@ast-grep/lang-ruby": "^0.0.7",
    "@ast-grep/lang-rust": "^0.0.7",
    "@ast-grep/lang-swift": "^0.0.8",
    "@ast-grep/lang-yaml": "^0.0.6",
    "@ast-grep/napi": "^0.42.3",
    "diff": "^9.0.0",
    "file-type": "^22.0.1",
    "oxc-parser": "^0.132.0",
    "typebox": "^1.1.38",
    "xxhashjs": "^0.2.2"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.75.3",
    "@types/bun": "latest",
    "@types/node": "^25.9.0",
    "@types/xxhashjs": "^0.2.4",
    "@typescript/native-preview": "^7.0.0-dev.20260518.1",
    "knip": "^6.14.1",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.75.0"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  }
}
